          "glob": "aether_cpp/src/**/*.cpp",
          "regex": "(?i)\\b(stub|placeholder|todo|fixme|minimal)\\b|integrate_stub",
          "description": "Phase 1 C++ implementation must be non-stub and non-minimal"
        },
        {
          "glob": "aether_cpp/src/tsdf/**/*.cpp",
          "regex": "\\bstd::(set|unordered_map|unordered_set|map|vector|deque|list)\\b",
          "description": "TSDF core path must not rely on mutable STL containers"
        },
        {
          "glob": "aether_cpp/src/tsdf_volume.cpp",
          "regex": "\\bstd::set\\b",
          "description": "TSDFVolume core path must not use std::set"
        }
