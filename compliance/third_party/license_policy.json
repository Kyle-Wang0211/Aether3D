{
  "policy_version": "1.0.0",
  "default_action": "deny",
  "allow_spdx": [
    "MIT",
    "Apache-2.0",
    "BSD-2-Clause",
    "BSD-3-Clause",
    "PSF-2.0"
  ],
  "conditional_allow_spdx": [
    "MPL-2.0"
  ],
  "deny_spdx": [
    "GPL-2.0",
    "GPL-3.0",
    "AGPL-3.0",
    "LGPL-2.1",
    "LGPL-3.0"
  ],
  "conditional_requirements": {
    "MPL-2.0": [
      "Legal approval ticket is required before release",
      "Distribution scope and source disclosure obligations must be documented"
    ]
  }
}
