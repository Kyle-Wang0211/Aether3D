 Future<void> _signFramework(Environment environment, File binary, BuildMode buildMode) async {
+  // Local patch (2026-04-25): skip codesign entirely for iOS Simulator builds.
+  // On macOS 14+ the com.apple.provenance xattr is kernel-protected (xattr -c
+  // / -d / ditto --noextattr all fail to remove it), and ad-hoc codesign
+  // refuses files with this xattr ("resource fork ... detritus not allowed").
+  // Simulator doesn't enforce codesign at runtime, so skipping is safe for
+  // simulator. Device / IPA builds still hit codesign below.
+  final String? sdkRoot = environment.defines[kSdkRoot];
+  if (sdkRoot != null && sdkRoot.contains('iPhoneSimulator')) {
+    environment.logger.printTrace('Skipping codesign for simulator build (provenance xattr workaround)');
+    return;
+  }
+
   await removeFinderExtendedAttributes(
     binary,
