# Uncomment this line to define a global platform for your project
platform :ios, '14.0'

# CocoaPods analytics sends network stats synchronously affecting flutter build latency.
ENV['COCOAPODS_DISABLE_STATS'] = 'true'

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}

def flutter_root
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'Generated.xcconfig'), __FILE__)
  unless File.exist?(generated_xcode_build_settings_path)
    raise "#{generated_xcode_build_settings_path} must exist. If you're running pod install manually, make sure flutter pub get is executed first"
  end

  File.foreach(generated_xcode_build_settings_path) do |line|
    matches = line.match(/FLUTTER_ROOT\=(.*)/)
    return matches[1].strip if matches
  end
  raise "FLUTTER_ROOT not found in #{generated_xcode_build_settings_path}. Try deleting Generated.xcconfig, then run flutter pub get"
end

require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper'), flutter_root)

flutter_ios_podfile_setup

target 'Runner' do
  # 2026-04-27 (evening): direct-launch crash on iPhone 14 Pro / iOS
  # 26.3.1. Crash log pinpointed `swift_getObjectType +40` inside
  # `SharedPreferencesPlugin.register(with:)` — Swift class metadata
  # couldn't be resolved at cold-launch when LLDB wasn't attached.
  # Standard Flutter + Firebase + iOS 26 fix is to flip Pods to use
  # frameworks with static linkage: CocoaPods produces .framework
  # bundles (which correctly export Swift class metadata) but links
  # them statically into the Runner binary (avoiding runtime dylib
  # issues).
  #
  # `:linkage => :static` preserves the zero-dylib distribution
  # profile the pre-Firebase Podfile comment cared about; it's how
  # Firebase-using Flutter apps are expected to configure today.
  #
  # use_modular_headers! stays — still needed by Firebase's Swift
  # pods to import their non-modular Objective-C deps.
  # EXP 3 (2026-04-28): Exp 2 ruled out aether3d_ffi / Dawn. Now test if
  # `use_frameworks! :linkage => :static` + `use_modular_headers!` combo
  # is the culprit (classic static-framework double-initialization / symbol
  # clash pattern). Comment both out and fall back to the stock default
  # (no `use_frameworks!` at all → plugins ship as static libraries;
  # Firebase pods that *require* modular headers will install them on a
  # per-pod basis via :modular_headers => true inside the pod() call).
  # use_frameworks! :linkage => :static   ← static linkage removed (Exp 3)
  use_modular_headers!                     # required by Firebase Swift pods
  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
  target 'RunnerTests' do
    inherit! :search_paths
  end

  # Restored 2026-04-28: Exp 2 ruled this pod out. The real root cause of
  # the black-screen was missing UIApplicationSceneManifest + SceneDelegate
  # (see ios/Runner/SceneDelegate.swift). Re-enabling Dawn-backed scene
  # renderer.
  pod 'aether3d_ffi', :path => '../../aether_cpp'
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)
  end

end
