# Uncomment this line to define a global platform for your project
platform :ios, '14.0'

# CocoaPods analytics sends network stats synchronously affecting flutter build latency.
ENV['COCOAPODS_DISABLE_STATS'] = 'true'

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}

def flutter_root
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'Generated.xcconfig'), __FILE__)
  unless File.exist?(generated_xcode_build_settings_path)
    raise "#{generated_xcode_build_settings_path} must exist. If you're running pod install manually, make sure flutter pub get is executed first"
  end

  File.foreach(generated_xcode_build_settings_path) do |line|
    matches = line.match(/FLUTTER_ROOT\=(.*)/)
    return matches[1].strip if matches
  end
  raise "FLUTTER_ROOT not found in #{generated_xcode_build_settings_path}. Try deleting Generated.xcconfig, then run flutter pub get"
end

require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper'), flutter_root)

flutter_ios_podfile_setup

target 'Runner' do
  # 2026-04-27 (evening): direct-launch crash on iPhone 14 Pro / iOS
  # 26.3.1. Crash log pinpointed `swift_getObjectType +40` inside
  # `SharedPreferencesPlugin.register(with:)` — Swift class metadata
  # couldn't be resolved at cold-launch when LLDB wasn't attached.
  # Standard Flutter + Firebase + iOS 26 fix is to flip Pods to use
  # frameworks with static linkage: CocoaPods produces .framework
  # bundles (which correctly export Swift class metadata) but links
  # them statically into the Runner binary (avoiding runtime dylib
  # issues).
  #
  # `:linkage => :static` preserves the zero-dylib distribution
  # profile the pre-Firebase Podfile comment cared about; it's how
  # Firebase-using Flutter apps are expected to configure today.
  #
  # use_modular_headers! stays — still needed by Firebase's Swift
  # pods to import their non-modular Objective-C deps.
  # EXP 3 (2026-04-28): Exp 2 ruled out aether3d_ffi / Dawn. Now test if
  # `use_frameworks! :linkage => :static` + `use_modular_headers!` combo
  # is the culprit (classic static-framework double-initialization / symbol
  # clash pattern). Comment both out and fall back to the stock default
  # (no `use_frameworks!` at all → plugins ship as static libraries;
  # Firebase pods that *require* modular headers will install them on a
  # per-pod basis via :modular_headers => true inside the pod() call).
  # use_frameworks! :linkage => :static   ← static linkage removed (Exp 3)
  use_modular_headers!                     # required by Firebase Swift pods
  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
  target 'RunnerTests' do
    inherit! :search_paths
  end

  # Restored 2026-04-28: Exp 2 ruled this pod out. The real root cause of
  # the black-screen was missing UIApplicationSceneManifest + SceneDelegate
  # (see ios/Runner/SceneDelegate.swift). Re-enabling Dawn-backed scene
  # renderer.
  pod 'aether3d_ffi', :path => '../../aether_cpp'
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)

    # Thermion's native framework needs iOS 13+. CocoaPods sometimes
    # downgrades IPHONEOS_DEPLOYMENT_TARGET back to Flutter's stock
    # 12.0 in the generated per-pod xcconfig; force it back so the
    # framework's Info.plist matches our LSMinimumSystemVersion=13.0
    # in Runner/Info.plist.
    target.build_configurations.each do |config|
      current = config.build_settings['IPHONEOS_DEPLOYMENT_TARGET']
      if current.nil? || current.to_f < 13.0
        config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '13.0'
      end
    end
  end

  # Thermion 0.3.4's ios/thermion_flutter.podspec line 25 ships:
  #   'OTHER_CFLAGS' => '"-fvisibility=default" "$(inherited)"'
  # The quoted "$(inherited)" wraps every inherited flag (including the
  # -fmodule-map-file=... chain CocoaPods generates for use_modular_headers!)
  # into one giant argument with leading whitespace, which clang then
  # tries to open as a file → "no such file or directory: ' -fmodule-map-file=...".
  # Strip the quotes from the generated Pods-Runner/Pods-RunnerTests
  # xcconfigs each pod install. Drop this hook when Thermion fixes upstream
  # (file an issue at github.com/nmfisher/thermion if it lingers).
  bad = '"-fvisibility=default" "$(inherited)"'
  good = '-fvisibility=default'
  Dir[File.join(installer.config.installation_root, 'Pods/Target Support Files/Pods-*/*.xcconfig')].each do |xcconfig|
    contents = File.read(xcconfig)
    if contents.include?(bad)
      File.write(xcconfig, contents.gsub(bad, good))
    end
  end

  # For App Store uploads, also run `bash ios/scripts/thermion_minos_fix.sh`
  # AFTER `flutter build ios --release` and BEFORE `xcodebuild archive`.
  # That script re-stamps MinimumOSVersion=13.0 inside the embedded
  # thermion_dart.framework/Info.plist directly, which is what App Store
  # Connect validates (and what the deployment-target override above
  # cannot reach for prebuilt binary frameworks).

  # ── onnxruntime-c force_load (MobileSAM via dart:ffi) ─────────────────
  #
  # The `onnxruntime` Flutter plugin (1.4.1) reaches into the
  # onnxruntime C library at runtime via dart:ffi
  # `DynamicLibrary.lookup('OrtSessionOptionsAppendExecutionProvider_CPU')`
  # and friends. The onnxruntime-c pod ships those symbols inside
  # `onnxruntime.xcframework`, and Pods-Runner.xcconfig already links
  # `-framework "onnxruntime"` — that's enough to satisfy the static
  # linker for any C function some Obj-C code (the onnxruntime-objc
  # wrapper) references by name.
  #
  # But the wrapper doesn't reference every C symbol — only the ones
  # its own Obj-C surface needs. The rest get dead-stripped, so
  # `dlsym(RTLD_DEFAULT, "OrtSessionOptionsAppendExecutionProvider_CPU")`
  # at Dart-side warmup returns NULL and `MobileSamInference.warmup()`
  # explodes with `symbol not found`.
  #
  # `-force_load` tells the linker to retain every symbol in the
  # specified framework binary, regardless of static reachability.
  # Bloats the Runner binary by ~30 MB (the entire onnxruntime C
  # runtime). Worth it — SAM is on the critical capture-quality path.
  #
  # We patch the generated xcconfig directly (not via
  # `config.build_settings = ...` on the ruby Project) because
  # CocoaPods writes the xcconfig in an earlier install phase than
  # the post_install hook fires; setting build_settings here would
  # update Pods.xcodeproj but not the .xcconfig the Runner target
  # actually reads. Same pattern as the thermion CFLAGS patch above.
  #
  # SDK-conditional because the xcframework slices live in different
  # subdirectories (device arm64 vs simulator arm64+x86_64).
  device_force_load = '-force_load "$(PODS_ROOT)/onnxruntime-c/onnxruntime.xcframework/ios-arm64/onnxruntime.framework/onnxruntime"'
  sim_force_load = '-force_load "$(PODS_ROOT)/onnxruntime-c/onnxruntime.xcframework/ios-arm64_x86_64-simulator/onnxruntime.framework/onnxruntime"'
  marker = 'onnxruntime.xcframework'
  Dir[File.join(installer.config.installation_root, 'Pods/Target Support Files/Pods-Runner/*.xcconfig')].each do |xcconfig|
    contents = File.read(xcconfig)
    next if contents.include?(marker) # idempotent
    appended = contents.dup
    # Append to existing OTHER_LDFLAGS[sdk=iphoneos*] / iphonesimulator*
    # lines if present; otherwise add a new line at end. Both lines
    # always exist for Pods-Runner because aether3d_ffi already adds
    # sdk-conditional ldflags upstream of us.
    [
      [/^OTHER_LDFLAGS\[sdk=iphoneos\*\] = (.*)$/, device_force_load],
      [/^OTHER_LDFLAGS\[sdk=iphonesimulator\*\] = (.*)$/, sim_force_load],
    ].each do |pattern, flag|
      if appended.match?(pattern)
        appended = appended.sub(pattern) { |m| "#{m} #{flag}" }
      else
        sdk = flag.include?('simulator') ? 'iphonesimulator*' : 'iphoneos*'
        appended += "\nOTHER_LDFLAGS[sdk=#{sdk}] = $(inherited) #{flag}\n"
      end
    end
    File.write(xcconfig, appended)
  end
end
